{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/app/$1"
    }
  ],
  "env": {
    "JWT_SECRET": "your-super-secret-jwt-key-change-in-production",
    "DB_HOST": "localhost",
    "DB_USER": "root", 
    "DB_PASSWORD": "",
    "DB_NAME": "ignite_lms"
  }
}
